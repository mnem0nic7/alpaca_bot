SHELL=/bin/bash
# Nightly evolve pipeline — runs 30 min after NYSE close (22:30 UTC = 5:30 PM ET year-round)
# apply_candidate.sh chains after nightly (&&) and restarts the supervisor if params changed.
# The env file must be sourced first: deploy/compose.yaml interpolates ${TRADING_MODE} etc.
# from the calling shell, exactly like scripts/deploy.sh does.
10 22 * * 1-5 root flock -n /var/lock/alpaca-bot-session-guard.lock /workspace/alpaca_bot/scripts/session_guard.sh /etc/alpaca_bot/alpaca-bot.env >> /var/log/alpaca-bot-session-guard.log 2>&1
20 22 * * 1-5 root flock -n /var/lock/alpaca-bot-profit-probe.lock /workspace/alpaca_bot/scripts/paper_profit_probe.sh /etc/alpaca_bot/alpaca-bot.env >> /var/log/alpaca-bot-profit-probe.log 2>&1
30 22 * * 1-5 root flock -n /var/lock/alpaca-bot-nightly.lock bash -lc 'mkdir -p /var/lib/alpaca-bot/nightly && cd /workspace/alpaca_bot && set -a && source /etc/alpaca_bot/alpaca-bot.env && set +a && docker compose -f deploy/compose.yaml run --rm nightly >> /var/log/alpaca-bot-nightly.log 2>&1 && ./scripts/apply_candidate.sh /etc/alpaca_bot/alpaca-bot.env >> /var/log/alpaca-bot-nightly.log 2>&1'
# Pre-open paper readiness — runs before NYSE open (13:20 UTC = 09:20 ET during EDT)
20 13 * * 1-5 root flock -n /var/lock/alpaca-bot-paper-readiness.lock /workspace/alpaca_bot/scripts/paper_readiness_check.sh /etc/alpaca_bot/alpaca-bot.env >> /var/log/alpaca-bot-paper-readiness.log 2>&1
0 16 * * 1-5 root flock -n /var/lock/alpaca-bot-paper-activity.lock /workspace/alpaca_bot/scripts/paper_activity_check.sh /etc/alpaca_bot/alpaca-bot.env >> /var/log/alpaca-bot-paper-activity.log 2>&1
