DATABASE_URL=postgresql://alpaca_bot:replace_me@postgres:5432/alpaca_bot
MARKET_DATA_FEED=iex
SYMBOLS=AAPL,MSFT,AMZN,NVDA,META,SPY,QQQ,IWM

DAILY_SMA_PERIOD=20
BREAKOUT_LOOKBACK_BARS=20
