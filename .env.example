# Runtime mode
TRADING_MODE=paper
ENABLE_LIVE_TRADING=false
STRATEGY_VERSION=v1-breakout

# Alpaca credentials
ALPACA_PAPER_API_KEY=your_paper_key_here
ALPACA_PAPER_SECRET_KEY=your_paper_secret_here
ALPACA_LIVE_API_KEY=
ALPACA_LIVE_SECRET_KEY=

# Infrastructure
DATABASE_URL=postgresql://alpaca_bot:password@db.example.com:5432/alpaca_bot
MARKET_DATA_FEED=sip

# Universe
SYMBOLS=AAPL,MSFT,AMZN,NVDA,META,SPY,QQQ,IWM

# Strategy defaults
DAILY_SMA_PERIOD=20
BREAKOUT_LOOKBACK_BARS=20
RELATIVE_VOLUME_LOOKBACK_BARS=20
RELATIVE_VOLUME_THRESHOLD=1.5
ENTRY_TIMEFRAME_MINUTES=15

# Risk defaults
RISK_PER_TRADE_PCT=0.0025
MAX_POSITION_PCT=0.05
MAX_OPEN_POSITIONS=3
DAILY_LOSS_LIMIT_PCT=0.01
STOP_LIMIT_BUFFER_PCT=0.001
BREAKOUT_STOP_BUFFER_PCT=0.001
ENTRY_STOP_PRICE_BUFFER=0.01

# Market windows (America/New_York)
ENTRY_WINDOW_START=10:00
ENTRY_WINDOW_END=15:30
FLATTEN_TIME=15:45

# Dashboard auth
DASHBOARD_AUTH_ENABLED=true
DASHBOARD_AUTH_USERNAME=operator@example.com
DASHBOARD_AUTH_PASSWORD_HASH='replace_me'
